# Template for 01-secrets.yaml
# Copy this file to 01-secrets.yaml and fill in real values:
#   cp 01-secrets.yaml.example 01-secrets.yaml
#
# Production: replace with External Secrets Operator pulling from
# Google Secret Manager (Stage 7).

apiVersion: v1
kind: Secret
metadata:
  name: postgres-secret
  namespace: llm-platform
type: Opaque
stringData:
  POSTGRES_USER: REPLACE_ME
  POSTGRES_PASSWORD: REPLACE_ME
  POSTGRES_DB: REPLACE_ME
  DATABASE_URL: postgresql://USER:PASS@postgres.llm-platform.svc.cluster.local:5432/DB

---
apiVersion: v1
kind: Secret
metadata:
  name: router-secret
  namespace: llm-platform
type: Opaque
stringData:
  ROUTER_MASTER_KEY: REPLACE_ME
