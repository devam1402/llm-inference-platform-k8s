# ──────────────────────────────────────────
# LLM Inference Platform — Config Template
# Copy to .env and fill in real values:
#   cp .env.example .env
# ──────────────────────────────────────────

# Core
ENV=local
LOG_LEVEL=INFO

# Router (LiteLLM)
ROUTER_PORT=4000
ROUTER_MASTER_KEY=replace_with_random_secret

# Worker
WORKER_PORT=8002
WORKER_CONCURRENCY=4
WORKER_MAX_INFLIGHT=8

# Cost Tracker
COST_TRACKER_PORT=8001

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=llmplatform
POSTGRES_USER=llm_user
POSTGRES_PASSWORD=replace_with_random_password

# Database URL
DATABASE_URL=postgresql://llm_user:replace_with_random_password@postgres:5432/llmplatform

# Ollama
OLLAMA_HOST=http://ollama:11434
OLLAMA_DEFAULT_MODEL=qwen2.5:0.5b

# Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
JAEGER_PORT=16686

# Router internal URL
ROUTER_URL=http://router:4000
