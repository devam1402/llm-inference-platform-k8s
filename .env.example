# ──────────────────────────────────────────
# LLM Inference Platform — Environment Config
# Copy to .env and fill in real values
# ──────────────────────────────────────────

# Project
PROJECT_NAME=llm-platform
ENVIRONMENT=local

# Ollama
OLLAMA_HOST=http://ollama:11434
OLLAMA_DEFAULT_MODEL=qwen2.5:0.5b

# Router (LiteLLM)
ROUTER_PORT=4000
ROUTER_MASTER_KEY=sk-local-dev-change-me
LITELLM_LOG=INFO

# Cost Tracker
COST_TRACKER_PORT=8001

# Worker
WORKER_CONCURRENCY=2

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=llmplatform
POSTGRES_USER=llmuser
POSTGRES_PASSWORD=changeme

# Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin
JAEGER_PORT=16686

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=llm-platform

# GCP (fill these later, in Stage 7)
GCP_PROJECT_ID=
GCP_REGION=us-central1
GCP_ZONE=us-central1-a

# Hugging Face (for downloading models on GCP later)
HF_TOKEN=
